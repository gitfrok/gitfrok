# Single source of truth for service image tags (local Minikube + version floor of record).
# See ADR-0023 (stack) and ADR-0024 (dev env).
POSTGRES_IMAGE=postgres:18
VALKEY_IMAGE=valkey/valkey:9.1
REDPANDA_IMAGE=redpandadata/redpanda:v26.1
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:4.40
ZITADEL_IMAGE=ghcr.io/zitadel/zitadel:latest

# Host tool floors (also in .tool-versions): go>=1.26  node>=26  tsc>=7  git>=2
# Local domain: *.gitsaas.test   TLS: mkcert wildcard   Cluster: Minikube (ingress+ingress-dns)
